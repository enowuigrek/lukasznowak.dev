    },
    {
      "page": "/projekt/peria/opengraph-image",
      "regex": "^/projekt/peria/opengraph\\-image(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projekt/peria/opengraph\\-image(?:/)?$"
    },
    {
      "page": "/projekt/strzykawa",
      "regex": "^/projekt/strzykawa(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projekt/strzykawa(?:/)?$"
    },
    {
      "page": "/projekt/strzykawa/opengraph-image",
      "regex": "^/projekt/strzykawa/opengraph\\-image(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projekt/strzykawa/opengraph\\-image(?:/)?$"
    },
    {
      "page": "/projekt/uknuta-magia",
      "regex": "^/projekt/uknuta\\-magia(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/projekt/uknuta\\-magia(?:/)?$"
    },
    {
      "page": "/projekt/uknuta-magia/opengraph-image",
      "regex": "^/projekt/uknuta\\-magia/opengraph\\-image(?:/)?$",
      "routeKeys": {},
